# ============================================================================
# Grafana Cloud credentials for the hardened Alloy config
# ============================================================================
#
# Copy this file and fill in your values, then load them into the Alloy
# service environment (on most distros: append to /etc/default/alloy or
# /etc/sysconfig/alloy — see docs/env-vars.md for details).
#
#   cp .env.example .env
#
# All values come from grafana.com → My Account → your stack.
# See docs/env-vars.md for the full reference.
# ============================================================================

# Read/write API key (shared password for Prometheus, Loki, and Fleet
# Management). Create via Access Policies → set:alloy-data-write scope.
# Copy the token value immediately — you only see it once.
GCLOUD_RW_API_KEY=glc_xxxxxxxxxxxxx

# --- Prometheus remote_write (from stack > Prometheus > Details) ---
GRAFANA_METRICS_URL=https://prometheus-prod-13-prod-us-east-0.grafana.net/api/prom/push
GRAFANA_METRICS_USERNAME=000000

# --- Loki remote_write (from stack > Loki > Details) ---
GRAFANA_LOGS_URL=https://logs-prod-006.grafana.net/loki/api/v1/push
GRAFANA_LOGS_USERNAME=000000

# ============================================================================
# Optional — only needed if you enable the (commented-out) remotecfg block
# in config.alloy for self-monitoring. Path 2 users (Fleet Management) use
# fleet-config.alloy instead, which sets these inline.
# ============================================================================

# GRAFANA_FLEET_URL=https://fleet-management-prod-008.grafana.net
# GRAFANA_FLEET_INSTANCE_ID=000000
