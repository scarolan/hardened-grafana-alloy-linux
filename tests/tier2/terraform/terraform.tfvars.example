# Copy to terraform.tfvars and fill in:
#   cp terraform.tfvars.example terraform.tfvars

project_id          = "your-gcp-project-id"
region              = "us-central1"
zone                = "us-central1-a"
ssh_public_key_path = "~/.ssh/id_rsa.pub"
ssh_user            = "testrunner"

